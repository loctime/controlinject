{
  "manifest_version": 3,
  "name": "Control Documentario",
  "description": "Automatiza la carga de documentos",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "scripting",
    "alarms",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "https://controldocumentario.com/*",
    "https://api.anthropic.com/*",
    "https://api.telegram.org/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://firestore.googleapis.com/*",
    "https://*.run.app/*",
    "https://*.cloudfunctions.net/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "icons": {
    "48": "icons/icon-48x48.png",
    "72": "icons/icon-72x72.png",
    "96": "icons/icon-96x96.png",
    "128": "icons/icon-128.png",
    "144": "icons/icon-144x144.png",
    "192": "icons/icon-192x192.png",
    "512": "icons/icon-512x512.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://controldocumentario.com/*"
      ],
      "js": [
        "page-inject-confirm-patch.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://controldocumentario.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://controldocumentario.com/*"
      ],
      "js": [
        "vencimientos.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "panel.html",
        "panel.css",
        "panel.js",
        "matcher.js",
        "storage.js",
        "imagedb.js",
        "pdf-splitter.js",
        "ocr-engine.js",
        "modal-seleccion.js",
        "page-inject-confirm-patch.js",
        "vencimientos.js",
        "mapeos.html",
        "mapeos.js",
        "options.html",
        "options.js",
        "pdf.min.js",
        "pdf.worker.min.js",
        "icons/*"
      ],
      "matches": [
        "https://controldocumentario.com/*"
      ]
    }
  ]
}
